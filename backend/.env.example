# =============================================================================
# Food City Backend — Environment Configuration
# Copy to `.env` and adjust. NEVER commit `.env`.
# =============================================================================

# --- App ---
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_LOG_LEVEL=info,food_city_backend=debug,sqlx=warn,hyper=warn
APP_REQUEST_ID_HEADER=X-Request-Id

# --- Database ---
DATABASE_URL=postgres://foodcity:foodcity@localhost:5432/foodcity
DATABASE_MAX_CONNECTIONS=20
DATABASE_ACQUIRE_TIMEOUT_SECS=5

# Read replica (leave empty to use primary for reads)
DATABASE_REPLICA_URL=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=16

# --- JWT ---
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_ISSUER=food-city
JWT_AUDIENCE=food-city-client
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://localhost:6379/1

# --- Geocoding (Nominatim is free / no key needed) ---
GEOCODER_PROVIDER=nominatim
GEOCODER_API_URL=https://nominatim.openstreetmap.org
GEOCODER_API_KEY=

# --- Map tiles (frontend uses this; backend proxies if needed) ---
MAP_TILES_PROVIDER=openstreetmap

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=food-city-backend

# --- Feature flags ---
FEATURE_REALTIME_WS=true
FEATURE_DRIVER_MATCHING=true
FEATURE_LOYALTY=true
