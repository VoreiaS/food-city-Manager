{
  "annotations": {
    "list": []
  },
  "description": "Food City backend metrics dashboard",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "Active Orders by State",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (status) (order_state_count)",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 }
    },
    {
      "title": "DB Pool Size",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "db_pool_size",
          "legendFormat": "total"
        },
        {
          "expr": "db_pool_idle",
          "legendFormat": "idle"
        }
      ],
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 }
    },
    {
      "title": "Redis Pool Configured",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_pool_configured",
          "legendFormat": "pool size"
        }
      ],
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 }
    }
  ],
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["food-city"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Food City Backend",
  "uid": "food-city",
  "version": 1
}
